{
  "name": "captains · frontend",
  "build": {
    "dockerfile": "../../frontend/Dockerfile",
    "context": "../../frontend"
  },
  "workspaceFolder": "/workspaces/captains",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/captains,type=bind,consistency=cached",
  "initializeCommand": ["docker", "compose", "-f", "${localWorkspaceFolder}/compose.yaml", "up", "-d", "mysql", "cosmosdb"],
  "runArgs": ["--network=captains_app-net"],
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": true,
      "installOhMyZsh": true,
      "username": "vscode",
      "userUid": "automatic",
      "userGid": "automatic",
      "configureZshAsDefaultShell": true
    },
    "ghcr.io/devcontainers/features/node:1": {
      "version": "22",
      "nodeGypDependencies": true,
      "installYarnUsingApt": false
    },
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "version": "latest",
      "dockerDashComposeVersion": "v2"
    }
  },
  "mounts": [
    "source=captains-claude-config,target=/home/vscode/.claude,type=volume",
    "source=captains-shell-history,target=/commandhistory,type=volume"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss",
        "streetsidesoftware.code-spell-checker",
        "mhutchie.git-graph",
        "donjayamanne.githistory",
        "github.vscode-github-actions",
        "gruntfuggly.todo-tree",
        "christian-kohler.npm-intellisense",
        "christian-kohler.path-intellisense",
        "oderwat.indent-rainbow",
        "shardulm94.trailing-spaces",
        "yzhang.markdown-all-in-one",
        "davidanson.vscode-markdownlint"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "terminal.integrated.defaultProfile.linux": "zsh"
      }
    }
  },
  "forwardPorts": [3000, 8000],
  "portsAttributes": {
    "3000": { "label": "Next.js (frontend)", "onAutoForward": "notify" },
    "8000": { "label": "FastAPI (backend)" }
  },
  "postCreateCommand": "sudo chown -R vscode:vscode /workspaces/captains /home/vscode/.claude /commandhistory 2>/dev/null || true && touch /home/vscode/.claude/.claude.json && ln -sf /home/vscode/.claude/.claude.json /home/vscode/.claude.json && chown vscode:vscode /home/vscode/.claude.json && npm config delete prefix 2>/dev/null || true && cd /workspaces/captains/frontend && npm install && . /usr/local/share/nvm/nvm.sh && npm install -g @anthropic-ai/claude-code",
  "postStartCommand": "cd /workspaces/captains/frontend && npm run dev",
  "remoteUser": "vscode"
}
