{
  "name": "captains · backend",
  "build": {
    "dockerfile": "../../backend/Dockerfile",
    "context": "../../backend"
  },
  "workspaceFolder": "/workspaces/captains",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/captains,type=bind,consistency=cached",
  "initializeCommand": ["docker", "compose", "-f", "${localWorkspaceFolder}/compose.yaml", "up", "-d", "mysql", "cosmosdb"],
  "runArgs": ["--network=captains_app-net"],
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": true,
      "installOhMyZsh": true,
      "username": "vscode",
      "userUid": "automatic",
      "userGid": "automatic",
      "configureZshAsDefaultShell": true
    },
    "ghcr.io/devcontainers/features/node:1": {
      "version": "22",
      "nodeGypDependencies": true,
      "installYarnUsingApt": false
    },
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "version": "latest",
      "moby": false
    }
  },
  "mounts": [
    "source=captains-claude-config,target=/home/vscode/.claude,type=volume",
    "source=captains-shell-history,target=/commandhistory,type=volume"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "streetsidesoftware.code-spell-checker",
        "charliermarsh.ruff",
        "mhutchie.git-graph",
        "donjayamanne.githistory",
        "github.vscode-github-actions",
        "gruntfuggly.todo-tree",
        "christian-kohler.path-intellisense",
        "oderwat.indent-rainbow",
        "shardulm94.trailing-spaces",
        "yzhang.markdown-all-in-one",
        "davidanson.vscode-markdownlint",
        "qwtel.sqlite-viewer"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/opt/venv/bin/python",
        "python.analysis.extraPaths": ["/workspaces/captains/backend"],
        "[python]": {
          "editor.defaultFormatter": "charliermarsh.ruff",
          "editor.formatOnSave": true
        },
        "terminal.integrated.defaultProfile.linux": "zsh"
      }
    }
  },
  "forwardPorts": [8000],
  "portsAttributes": {
    "8000": { "label": "FastAPI (backend)", "onAutoForward": "notify" }
  },
  "postCreateCommand": "sudo chown -R vscode:vscode /home/vscode/.claude /commandhistory /opt/venv 2>/dev/null || true && touch /home/vscode/.claude/.claude.json && ln -sf /home/vscode/.claude/.claude.json /home/vscode/.claude.json && chown vscode:vscode /home/vscode/.claude.json && npm config delete prefix 2>/dev/null || true && cd /workspaces/captains/backend && uv sync --frozen && . /usr/local/share/nvm/nvm.sh && npm install -g @anthropic-ai/claude-code",
  "postAttachCommand": "cd /workspaces/captains/backend && uv run uvicorn app.main:app --host 0.0.0.0 --port 8000 --reload",
  "remoteUser": "vscode"
}
